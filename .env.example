# PrOSINT Configuration
# Copy this file to .env and fill in your API keys

# Shodan API key (https://account.shodan.io)
SHODAN_API_KEY=

# HIBP API key (https://haveibeenpwned.com/API/Key)
HIBP_API_KEY=

# Custom User-Agent for requests
USER_AGENT=PrOSINT/1.0

# Cache expiration in hours
CACHE_TTL=24

# Maximum concurrent requests
MAX_CONCURRENT=10

# Request timeout in seconds
REQUEST_TIMEOUT=30
